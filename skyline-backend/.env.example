# Database
DATABASE_URL=postgresql://username:password@localhost:5432/skyline

# Card/Bank Account Settings (for Russian payments)
# These details will be displayed to users on the payment instructions page
CARD_NUMBER=1234567890123456
CARD_HOLDER_NAME=Your Name
CARD_BANK_NAME=Sberbank

# JWT Security
JWT_SECRET=your-super-secret-jwt-token
JWT_REFRESH_SECRET=your-super-secret-refresh-token

# Admin Settings
ADMIN_EMAIL=admin@skyline-transfers.com

# Client URLs
CLIENT_URL=http://localhost:5173

# Exchange Rate Provider (Optional, default is fixed)
EXCHANGE_RATE_PROVIDER=manual

# Server Configuration
PORT=5000
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
