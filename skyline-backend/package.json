{
  "name": "skyline-backend",
  "version": "1.0.0",
  "description": "Backend API for SKYLINE Transfers",
  "main": "dist/server.js",
  "scripts": {
    "start": "node --max-old-space-size=512 dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only --no-notify --exit-child -- src/server.ts",
    "build": "node --max-old-space-size=1024 ./node_modules/.bin/tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:init": "ts-node src/scripts/init-db.ts",
    "db:create-admin": "ts-node src/scripts/create-admin.ts",
    "oauth:get-google-tokens": "ts-node-dev --transpile-only scripts/google-oauth-get-tokens.ts",
    "prestart": "npm run build"
  },
  "keywords": [
    "node",
    "typescript",
    "express",
    "postgresql",
    "prisma"
  ],
  "author": "SKYLINE Transfers Team",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@types/web-push": "^3.6.4",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "googleapis": "^161.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "prisma": "^4.16.2",
    "rate-limit-redis": "^4.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "prisma": {
    "seed": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  }
}
